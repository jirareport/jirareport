# Copy to scripts/.env (gitignored) and fill in your values:
#   cp scripts/.env.example scripts/.env

# App under test
BASE=http://localhost:8080

# Jira instance + credentials (Jira Cloud: email + API token)
JIRA_BASE=https://your-domain.atlassian.net
JIRA_USER=you@example.com
JIRA_PASS=your_jira_api_token

# Jira Agile board id; discovery derives EXT_ID + ordered columns from it
JIRA_BOARD_ID=0

# Optional: 1 = leave created resources in place (default 0 = clean up)
NO_CLEANUP=0
